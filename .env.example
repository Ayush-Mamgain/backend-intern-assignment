# Copy this file to .env and adjust if needed

# Port the Express server listens on
PORT=3000

# SQLite database file (used by Prisma)
DATABASE_URL="file:./dev.db"

# Base URL of the FastAPI analysis service (the mock service in fastapi-mock/)
FASTAPI_URL="http://localhost:8000"

# How long (ms) to wait for the FastAPI service before giving up
FASTAPI_TIMEOUT_MS=5000
